{
  "name": "turbolite",
  "version": "0.4.1",
  "description": "Compressed SQLite — transparent zstd compression via a custom VFS",
  "main": "index.js",
  "types": "index.d.ts",
  "bin": {
    "turbolite": "bin/turbolite.js"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "turbolite.*.node",
    "bin/turbolite.js",
    "turbolite",
    "turbolite.exe"
  ],
  "napi": {
    "name": "turbolite",
    "triples": {
      "defaults": true,
      "additional": [
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-gnu",
        "x86_64-unknown-linux-gnu"
      ]
    }
  },
  "license": "Apache-2.0",
  "keywords": ["sqlite", "compression", "zstd", "database", "vfs"],
  "devDependencies": {
    "@napi-rs/cli": "^2"
  },
  "scripts": {
    "build": "napi build --release --platform",
    "build-debug": "napi build --platform"
  }
}
